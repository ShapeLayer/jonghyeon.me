{
  "name": "jonghyeon.me",
  "private": true,
  "version": "0.0.1",
  "type": "module",
  "scripts": {
    "dev": "vite dev",
    "build": "pnpm run build:gh",
    "build:gh": "vite build",
    "build:cf": "DEPLOY_TARGET=cloudflare vite build",
    "preview": "vite preview",
    "preview:cf": "pnpm run build:cf && wrangler dev",
    "prepare": "svelte-kit sync || echo ''",
    "check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
    "check:watch": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch",
    "format": "prettier --write .",
    "lint": "prettier --check . && eslint .",
    "gen": "wrangler types",
    "deploy": "pnpm run deploy:cf",
    "deploy:cf": "pnpm run build:cf && wrangler deploy",
    "cf-typegen": "wrangler types"
  },
  "devDependencies": {
    "@eslint/compat": "^1.4.1",
    "@eslint/js": "^9.39.4",
    "@sveltejs/adapter-cloudflare": "^7.2.6",
    "@sveltejs/adapter-static": "^3.0.10",
    "@sveltejs/kit": "^2.53.4",
    "@sveltejs/vite-plugin-svelte": "^6.2.4",
    "@tailwindcss/vite": "^4.2.1",
    "@types/smoothscroll-polyfill": "^0.3.4",
    "eslint": "^9.39.4",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-svelte": "^3.15.2",
    "globals": "^16.5.0",
    "prettier": "^3.8.1",
    "prettier-plugin-svelte": "^3.5.1",
    "smoothscroll-polyfill": "^0.4.4",
    "svelte": "^5.53.10",
    "svelte-check": "^4.4.5",
    "tailwindcss": "^4.2.1",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.57.0",
    "vite": "^7.3.1",
    "wrangler": "^4.63.0"
  },
  "dependencies": {
    "@inlang/paraglide-js": "^2.14.0"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "esbuild"
    ]
  }
}
